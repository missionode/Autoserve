generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuthProvider {
  PASSWORD
  GOOGLE
  MOBILE_OTP
  STAFF_ID
}

enum RestaurantStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
  CLOSED
}

enum MembershipRole {
  ADMIN
  STAFF
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum LicenceStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  REPLACED
}

enum ApprovalDecisionType {
  SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
  REACTIVATED
}

enum CatalogRecordStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AvailabilityStatus {
  AVAILABLE
  LIMITED
  TEMPORARILY_UNAVAILABLE
  SOLD_OUT_TODAY
}

enum CartStatus {
  ACTIVE
  CHECKOUT_PENDING
  CONVERTED
  EXPIRED
  ABANDONED
}

model User {
  id                String                 @id @default(uuid()) @db.Uuid
  displayName       String                 @map("display_name")
  primaryEmail      String?                @unique @map("primary_email")
  primaryMobile     String?                @unique @map("primary_mobile")
  status            UserStatus             @default(PENDING_VERIFICATION)
  version           Int                    @default(1)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  authIdentities    AuthIdentity[]
  memberships       RestaurantMembership[]
  approvalDecisions ApprovalDecision[]     @relation("ApprovalActor")
  carts             Cart[]

  @@map("users")
}

model AuthIdentity {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  provider         AuthProvider
  providerSubject  String       @map("provider_subject")
  normalizedHandle String?      @map("normalized_handle")
  verifiedAt       DateTime?    @map("verified_at") @db.Timestamptz(3)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@unique([provider, normalizedHandle])
  @@index([userId])
  @@map("auth_identities")
}

model Restaurant {
  id                String                 @id @default(uuid()) @db.Uuid
  legalName         String                 @map("legal_name")
  displayName       String                 @map("display_name")
  slug              String                 @unique
  status            RestaurantStatus       @default(DRAFT)
  timezone          String                 @default("Asia/Kolkata")
  currencyCode      String                 @default("INR") @map("currency_code") @db.Char(3)
  complaintPhone    String?                @map("complaint_phone")
  version           Int                    @default(1)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships       RestaurantMembership[]
  licences          RestaurantLicence[]
  tables            RestaurantTable[]
  counters          PickupCounter[]
  approvalDecisions ApprovalDecision[]
  categories        Category[]
  menuItems         MenuItem[]
  itemAvailability  MenuItemAvailability[]
  carts             Cart[]

  @@map("restaurants")
}

model RestaurantMembership {
  id           String           @id @default(uuid()) @db.Uuid
  restaurantId String           @map("restaurant_id") @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  role         MembershipRole
  status       MembershipStatus @default(INVITED)
  staffCode    String?          @map("staff_code")
  version      Int              @default(1)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, userId])
  @@unique([restaurantId, staffCode])
  @@index([userId, status])
  @@index([restaurantId, role, status])
  @@map("restaurant_memberships")
}

model RestaurantLicence {
  id               String        @id @default(uuid()) @db.Uuid
  restaurantId     String        @map("restaurant_id") @db.Uuid
  licenceType      String        @map("licence_type")
  licenceNumber    String?       @map("licence_number")
  privateObjectKey String        @map("private_object_key")
  status           LicenceStatus @default(PENDING_REVIEW)
  issuedAt         DateTime?     @map("issued_at") @db.Date
  expiresAt        DateTime?     @map("expires_at") @db.Date
  version          Int           @default(1)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, licenceType, licenceNumber], map: "restaurant_licences_restaurant_id_licence_type_licence_number_k")
  @@index([restaurantId, status, expiresAt])
  @@map("restaurant_licences")
}

model RestaurantTable {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  code         String
  displayName  String     @map("display_name")
  capacity     Int?
  isActive     Boolean    @default(true) @map("is_active")
  version      Int        @default(1)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
  @@map("restaurant_tables")
}

model PickupCounter {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  code         String
  displayName  String     @map("display_name")
  isActive     Boolean    @default(true) @map("is_active")
  version      Int        @default(1)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
  @@map("pickup_counters")
}

model ApprovalDecision {
  id            String               @id @default(uuid()) @db.Uuid
  restaurantId  String               @map("restaurant_id") @db.Uuid
  decision      ApprovalDecisionType
  reason        String?
  decidedById   String?              @map("decided_by_id") @db.Uuid
  decidedAt     DateTime             @default(now()) @map("decided_at") @db.Timestamptz(3)
  correlationId String               @map("correlation_id") @db.Uuid
  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  decidedBy     User?                @relation("ApprovalActor", fields: [decidedById], references: [id], onDelete: Restrict)

  @@index([restaurantId, decidedAt])
  @@index([decidedById, decidedAt])
  @@index([correlationId])
  @@map("approval_decisions")
}

model Category {
  id           String              @id @default(uuid()) @db.Uuid
  restaurantId String              @map("restaurant_id") @db.Uuid
  name         String
  slug         String
  sortOrder    Int                 @default(0) @map("sort_order")
  status       CatalogRecordStatus @default(DRAFT)
  version      Int                 @default(1)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  menuItems    MenuItem[]

  @@unique([restaurantId, slug])
  @@unique([id, restaurantId])
  @@index([restaurantId, status, sortOrder])
  @@map("categories")
}

model MenuItem {
  id           String                @id @default(uuid()) @db.Uuid
  restaurantId String                @map("restaurant_id") @db.Uuid
  categoryId   String                @map("category_id") @db.Uuid
  name         String
  slug         String
  description  String?
  priceMinor   BigInt                @map("price_minor")
  currencyCode String                @default("INR") @map("currency_code") @db.Char(3)
  isVegetarian Boolean               @default(false) @map("is_vegetarian")
  status       CatalogRecordStatus   @default(DRAFT)
  version      Int                   @default(1)
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  category     Category              @relation(fields: [categoryId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  availability MenuItemAvailability?
  cartLines    CartLine[]

  @@unique([restaurantId, slug])
  @@unique([id, restaurantId])
  @@index([restaurantId, categoryId, status])
  @@map("menu_items")
}

model MenuItemAvailability {
  id               String             @id @default(uuid()) @db.Uuid
  restaurantId     String             @map("restaurant_id") @db.Uuid
  menuItemId       String             @unique @map("menu_item_id") @db.Uuid
  status           AvailabilityStatus @default(AVAILABLE)
  remainingCount   Int?               @map("remaining_count")
  unavailableUntil DateTime?          @map("unavailable_until") @db.Timestamptz(3)
  reason           String?
  version          Int                @default(1)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  menuItem         MenuItem           @relation(fields: [menuItemId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@unique([menuItemId, restaurantId])
  @@index([restaurantId, status])
  @@map("menu_item_availability")
}

model Cart {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  customerId   String?    @map("customer_id") @db.Uuid
  guestKey     String?    @map("guest_key")
  status       CartStatus @default(ACTIVE)
  currencyCode String     @default("INR") @map("currency_code") @db.Char(3)
  expiresAt    DateTime   @map("expires_at") @db.Timestamptz(3)
  version      Int        @default(1)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  customer     User?      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines        CartLine[]

  @@unique([id, restaurantId])
  @@index([restaurantId, status, expiresAt])
  @@index([customerId, status])
  @@index([guestKey, status])
  @@map("carts")
}

model CartLine {
  id                     String   @id @default(uuid()) @db.Uuid
  restaurantId           String   @map("restaurant_id") @db.Uuid
  cartId                 String   @map("cart_id") @db.Uuid
  menuItemId             String   @map("menu_item_id") @db.Uuid
  quantity               Int
  itemNameSnapshot       String   @map("item_name_snapshot")
  unitPriceMinorSnapshot BigInt   @map("unit_price_minor_snapshot")
  lineTotalMinor         BigInt   @map("line_total_minor")
  configurationSnapshot  Json     @default("{}") @map("configuration_snapshot") @db.JsonB
  version                Int      @default(1)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  cart                   Cart     @relation(fields: [cartId, restaurantId], references: [id, restaurantId], onDelete: Cascade)
  menuItem               MenuItem @relation(fields: [menuItemId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, cartId])
  @@index([restaurantId, menuItemId])
  @@map("cart_lines")
}

model FoundationProbe {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("foundation_probes")
}
