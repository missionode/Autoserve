FROM node:22.17.0-alpine
WORKDIR /workspace
COPY package.json package-lock.json .npmrc ./
COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts
COPY tsconfig.base.json eslint.config.mjs .prettierrc.json ./
RUN npm ci && npm run generate -w @autoserve/database
ARG AUTOSERVE_SERVICE
ENV AUTOSERVE_SERVICE=${AUTOSERVE_SERVICE}
CMD ["sh", "-c", "npm run dev -w @autoserve/${AUTOSERVE_SERVICE}"]
